{
  "name": "schole-landing-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "experiment": "tsx scripts/run-experiment.ts",
    "demo": "tsx scripts/generate-demo-run.ts",
    "migrate:supabase": "tsx scripts/migrate-to-supabase.ts",
    "reset:lab": "tsx scripts/reset-lab.ts",
    "prepare:demo-preload": "tsx scripts/prepare-demo-preload.ts",
    "setup:demo": "tsx scripts/reset-lab.ts && tsx scripts/prepare-demo-preload.ts",
    "deploy:html": "tsx scripts/regenerate-variant-html.ts",
    "aa-test": "tsx scripts/aa-test.ts",
    "prepare:baseline": "tsx scripts/prepare-baseline-html.ts",
    "prepare:variants": "tsx scripts/prepare-variant-html.ts",
    "prepare:pages": "npm run prepare:baseline && npm run prepare:variants",
    "predev": "npm run prepare:pages",
    "prebuild": "npm run prepare:pages"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
    "posthog-js": "^1.396.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
